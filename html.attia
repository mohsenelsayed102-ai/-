<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8">
  <title>نتيجة الشهادة الثانوية - مدرسة الشهيد ملازم اول حمادة فهمي مباشر</title>
  <meta name="description" content="بوابة نتائج الشهادة الثانوية - مدرسة الشهيد ملازم اول حمادة فهمي مباشر الثانوية المشتركة - استعلم عن النتيجة برقم الجلوس">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" type="image/png" href="logo.png">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">

  <style>
    /* المتغيرات والألوان الرسمية المستخرجة من موقعك (Gov Design System) */
    :root {
      --gov-navy: #003366;
      --gov-navy-dark: #002244;
      --gov-navy-light: #004488;
      --gov-blue: #005A9C;
      --gov-blue-light: #0070C0;
      --gov-gold: #D4AF37;
      --gov-gold-light: #E8C84A;
      --gov-gold-dark: #B8960F;
      --gov-bg: #F5F7FA;
      --gov-bg-alt: #EDF0F5;
      --gov-white: #FFFFFF;
      --gov-text: #1A1A2E;
      --gov-text-light: #4A4A6A;
      --gov-text-muted: #7A7A9A;
      --gov-border: #D8DCE6;
      --gov-border-light: #E8ECF2;
      --gov-success: #27AE60;
      --gov-success-bg: #E8F8F0;
      --gov-danger: #E74C3C;
      --gov-danger-bg: #FDF0EF;
      
      --font-primary: "Cairo", "Tajawal", -apple-system, sans-serif;
      --gov-shadow: 0 4px 20px rgba(0, 51, 102, 0.08);
      --gov-shadow-lg: 0 8px 32px rgba(0, 51, 102, 0.12);
      --gov-radius-md: 12px;
      --gov-radius-lg: 16px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: var(--font-primary);
      background-color: var(--gov-bg);
      color: var(--gov-text);
      line-height: 1.7;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 40px 20px;
    }

    /* الحاوية الرئيسية للهيكل الملكي */
    .gov-card {
      background-color: var(--gov-white);
      border-top: 6px solid var(--gov-navy);
      border-radius: var(--gov-radius-lg);
      box-shadow: var(--gov-shadow-lg);
      width: 100%;
      max-width: 600px;
      padding: 35px 25px;
      text-align: center;
      margin-top: 20px;
      border-bottom: 4px solid var(--gov-gold);
    }

    .header-logo {
      width: 90px;
      height: auto;
      margin-bottom: 15px;
    }

    h1 {
      font-size: 22px;
      color: var(--gov-navy-dark);
      font-weight: 700;
      margin-bottom: 8px;
    }

    .subtitle {
      font-size: 15px;
      color: var(--gov-text-light);
      margin-bottom: 30px;
      font-weight: 500;
    }

    /* صندوق المدخلات للبحث */
    .search-group {
      margin-bottom: 25px;
    }

    .search-group label {
      display: block;
      text-align: right;
      font-size: 14px;
      font-weight: 600;
      color: var(--gov-navy);
      margin-bottom: 8px;
    }

    input[type="number"] {
      width: 100%;
      padding: 14px;
      border: 2px solid var(--gov-border);
      border-radius: var(--gov-radius-md);
      font-size: 16px;
      font-family: var(--font-primary);
      text-align: center;
      outline: none;
      transition: all 0.25s ease;
      color: var(--gov-text);
      background-color: var(--gov-bg-alt);
    }

    input[type="number"]:focus {
      border-color: var(--gov-blue);
      background-color: var(--gov-white);
      box-shadow: 0 0 0 4px rgba(0, 90, 156, 0.1);
    }

    /* إزالة الأسهم الافتراضية من حقل الأرقام */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }

    .btn-submit {
      width: 100%;
      padding: 14px;
      background-color: var(--gov-navy);
      color: var(--gov-white);
      border: none;
      border-radius: var(--gov-radius-md);
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s ease;
      font-family: var(--font-primary);
    }

    .btn-submit:hover {
      background-color: var(--gov-navy-light);
    }

    /* لوحة عرض النتيجة والدرجات */
    .result-panel {
      display: none;
      margin-top: 25px;
      text-align: right;
      border-top: 2px dashed var(--gov-border);
      padding-top: 25px;
    }

    .result-title {
      text-align: center;
      color: var(--gov-navy);
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 20px;
    }

    .data-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 8px;
      border-bottom: 1px solid var(--gov-border-light);
    }

    .data-row:last-child {
      border-bottom: none;
    }

    .data-label {
      color: var(--gov-text-light);
      font-weight: 600;
      font-size: 14px;
    }

    .data-value {
      color: var(--gov-text);
      font-weight: 700;
      font-size: 15px;
    }

    .status-badge {
      padding: 4px 12px;
      border-radius: 50px;
      font-size: 13px;
      font-weight: 700;
    }

    .status-success {
      background-color: var(--gov-success-bg);
      color: var(--gov-success);
    }

    .alert-message {
      display: none;
      margin-top: 15px;
      padding: 12px;
      border-radius: var(--gov-radius-md);
      font-size: 14px;
      font-weight: 600;
      background-color: var(--gov-danger-bg);
      color: var(--gov-danger);
    }

    .loading-spinner {
      display: none;
      margin: 20px auto;
      width: 35px;
      height: 35px;
      border: 4px solid var(--gov-border-light);
      border-top-color: var(--gov-gold);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .btn-back {
      width: 100%;
      padding: 12px;
      background-color: var(--gov-bg-alt);
      color: var(--gov-navy);
      border: 1px solid var(--gov-border);
      border-radius: var(--gov-radius-md);
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 20px;
      font-family: var(--font-primary);
    }

    .btn-back:hover {
      background-color: var(--gov-border-light);
    }

    footer {
      margin-top: 35px;
      font-size: 12px;
      color: var(--gov-text-muted);
      font-weight: 500;
    }
  </style>
</head>
<body>

  <div class="gov-card">
    <img src="logo.png" alt="شعار وزارة التربية والتعليم" class="header-logo">
    <h1>مدرسة الشهيد ملازم أول حمادة فهمي مباشر الثانوية</h1>
    <div class="subtitle">بوابة نتائج الشهادة الثانوية المشتركة</div>

    <div id="search-section">
      <div class="search-group">
        <label for="seat-code">الاستعلام برقم الجلوس رسميًا:</label>
        <input type="number" id="seat-code" placeholder="أدخل رقم جلوس الطالب المكون من أرقام...">
      </div>
      <button class="btn-submit" onclick="searchResult()">استعلام عن النتيجة</button>
    </div>

    <div id="loader" class="loading-spinner"></div>

    <div id="alert-box" class="alert-message"></div>

    <div id="result-section" class="result-panel">
      <div class="result-title">بيانات اعتماد درجات الطالب</div>
      
      <div class="data-row">
        <span class="data-label">اسم الطالب رباعي:</span>
        <span class="data-value" id="out-name">-</span>
      </div>
      <div class="data-row">
        <span class="data-label">رقم جلوس الطالب:</span>
        <span class="data-value" id="out-seat">-</span>
      </div>
      <div class="data-row">
        <span class="data-label">المجموع الكلي المعتمد:</span>
        <span class="data-value" id="out-total">-</span>
      </div>
      <div class="data-row">
        <span class="data-label">النسبة المئوية الكلية:</span>
        <span class="data-value" id="out-percent" style="color: var(--gov-blue); font-weight: 800;">-</span>
      </div>
      <div class="data-row">
        <span class="data-label">حالة الاعتماد العام:</span>
        <span class="status-badge status-success" id="out-status">ناجح</span>
      </div>

      <button class="btn-back" onclick="resetForm()">العودة لاستعلام جديد</button>
    </div>
  </div>

  <footer>جميع الحقوق محفوظة لمدرسة الشهيد حمادة فهمي مباشر © 2026</footer>

  <script>
    // ضع هنا رابط الـ Web App الخاص بـ Google Apps Script الذي يجلب بيانات الـ Sheets
    const WEB_APP_URL = "https://script.google.com/macros/s/AKfycbx00I2C8ggJbaOsqN2PSzjrNBPw8jMePctm3heA62u1_bgWcow72IjHUhqeBHcJR5wZ/exec"; 

    function searchResult() {
      const seatValue = document.getElementById('seat-code').value.trim();
      const searchBox = document.getElementById('search-section');
      const resultBox = document.getElementById('result-section');
      const alertBox = document.getElementById('alert-box');
      const loader = document.getElementById('loader');

      // تصفير وتنظيف الحالات السابقة
      alertBox.style.display = "none";
      resultBox.style.display = "none";

      if (!seatValue) {
        alertBox.innerText = "تنبيه: حقل رقم الجلوس مطلوب للاستعلام.";
        alertBox.style.display = "block";
        return;
      }

      // إظهار الدوران للتحميل
      loader.style.display = "block";

      // دالة الجلب والربط البرمجي بالـ API
      fetch(`${WEB_APP_URL}?seatNumber=${seatValue}`)
        .then(response => response.json())
        .then(data => {
          loader.style.display = "none";

          if (data && data.status === "success") {
            // إخفاء مدخلات البحث لتقديم النتيجة بنقاء
            searchBox.style.display = "none";

            // تعبئة البيانات في الخانات المناسبة
            document.getElementById('out-name').innerText = data.studentName;
            document.getElementById('out-seat').innerText = data.seatNumber;
            document.getElementById('out-total').innerText = data.totalScore;
            document.getElementById('out-percent').innerText = data.percentage + "%";
            document.getElementById('out-status').innerText = data.studentStatus || "ناجح";

            // إظهار لوحة النتيجة كاملة
            resultBox.style.display = "block";
          } else {
            alertBox.innerText = "خطأ: رقم الجلوس المدخل غير مدرج بملفات النتيجة الحالية.";
            alertBox.style.display = "block";
          }
        })
        .catch(err => {
          loader.style.display = "none";
          alertBox.innerText = "فشل الاتصال: يرجى التحقق من جودة الإنترنت وإعادة المحاولة.";
          alertBox.style.display = "block";
          console.error("Fetch Error:", err);
        });
    }

    function resetForm() {
      document.getElementById('seat-code').value = "";
      document.getElementById('result-section').style.display = "none";
      document.getElementById('search-section').style.display = "block";
    }
  </script>
</body>
</html>
